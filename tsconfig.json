{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@fixtures": ["fixtures/index.ts"],
      "@pages/*": ["pages/*"],
      "@utils/*": ["utils/*"],
      "@data/*": ["test-data/*"],
      "@types/*": ["types/*"]
    },
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "tests/visual"],
  "exclude": ["node_modules", "dist", "playwright-report", "test-results"]
}